#include <Wire.h>
#include <Arduino_LED_Matrix.h>

ArduinoLEDMatrix matrix;

// -------------------- PINS --------------------
#define MPU_ADDR 0x68
#define VIB_PIN 7
#define BUZZER_PIN 8

// -------------------- VARIABLES ---------------
int16_t gx, gy, gz;
float gyroMag = 0;

int vibCount = 0;
unsigned long vibTimer = 0;

// -------------------- LED FRAMES ---------------
const uint32_t FRAME_OFF[3] = {
  0x00000000,
  0x00000000,
  0x00000000
};

const uint32_t FRAME_MILD[3] = {
  0x00001800,
  0x00003C00,
  0x00001800
};

const uint32_t FRAME_INTENSE[3] = {
  0xFFFFFFFF,
  0xFFFFFFFF,
  0xFFFFFFFF
};

// -------------------- SETUP --------------------
void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(VIB_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  Wire.begin();
  Wire.setClock(100000);

  // Wake MPU6050
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x6B);
  Wire.write(0x00);
  Wire.endTransmission(true);

  matrix.begin();
  matrix.loadFrame(FRAME_OFF);

  Serial.println("Tremor Detection System READY (Vibration-Gated)");
}

// -------------------- LOOP ---------------------
void loop() {
  readMPU6050();
  readVibrationSensor();
  classifyDisplayAndAlert();

  delay(20); // ~50 Hz
}

// -------------------- MPU6050 ------------------
void readMPU6050() {
  Wire.beginTransmission(MPU_ADDR);
  Wire.write(0x43);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU_ADDR, 6, true);

  if (Wire.available() == 6) {
    gx = Wire.read() << 8 | Wire.read();
    gy = Wire.read() << 8 | Wire.read();
    gz = Wire.read() << 8 | Wire.read();

    gyroMag = sqrt(
      (float)gx * gx +
      (float)gy * gy +
      (float)gz * gz
    );
  }
}

// -------------------- VIBRATION ----------------
void readVibrationSensor() {
  if (digitalRead(VIB_PIN) == HIGH) {
    vibCount++;
  }

  if (millis() - vibTimer >= 1000) {
    vibTimer = millis();
    vibCount = 0;
  }
}

// -------------------- CLASSIFY + OUTPUT --------
void classifyDisplayAndAlert() {
  static unsigned long lastBlink = 0;
  static bool blinkState = false;

  String severity;

  // 🔒 GATING CONDITION
  if (vibCount == 0) {
    severity = "NO TREMOR";
    matrix.loadFrame(FRAME_OFF);
    digitalWrite(BUZZER_PIN, LOW);
  }
  else {
    // Vibration detected → evaluate MPU
    if (gyroMag < 20000) {
      severity = "MILD TREMOR";
      digitalWrite(BUZZER_PIN, LOW);

      if (millis() - lastBlink > 600) {
        blinkState = !blinkState;
        matrix.loadFrame(blinkState ? FRAME_MILD : FRAME_OFF);
        lastBlink = millis();
      }
    }
    else {
      severity = "INTENSE TREMOR";
      digitalWrite(BUZZER_PIN, HIGH);

      if (millis() - lastBlink > 120) {
        blinkState = !blinkState;
        matrix.loadFrame(blinkState ? FRAME_INTENSE : FRAME_OFF);
        lastBlink = millis();
      }
    }
  }

  // -------------------- SERIAL DEBUG ------------
  Serial.print("GyroMag: ");
  Serial.print(gyroMag);
  Serial.print(" | VibCount: ");
  Serial.print(vibCount);
  Serial.print(" | Severity: ");
  Serial.println(severity);
}
